prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: omnivoice
Description: GGML port of OmniVoice multilingual TTS, public C ABI
URL: https://github.com/Serveurperso/omnivoice.cpp
Version: 0
Libs: -L${libdir} -lomnivoice
Cflags: -I${includedir}
